{
  "info": {
    "name": "Lookup API functional (by OpenAPI tags)",
    "description": "Folders match OpenAPI tags: PlatformAdmin, Namespaces, LookupTables, TableVersions, Entries, Imports, Exports. Run Setup first. For 10k company demo (`npm run seed:company`), use `postman/company-lookup.postman_collection.json`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": { "type": "noauth" },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('tenantSlug')) {",
          "  pm.collectionVariables.set('tenantSlug', 'fn-' + Date.now());",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Setup",
      "description": "Creates tenant, namespace, and table used by the rest of this collection.",
      "item": [
        {
          "name": "Create tenant",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const j = pm.response.json();",
                  "pm.collectionVariables.set('tenantId', j.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Functional\",\n  \"slug\": \"{{tenantSlug}}\"\n}"
            },
            "url": "{{baseUrl}}/tenants"
          }
        },
        {
          "name": "Create namespace",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const j = pm.response.json();",
                  "pm.collectionVariables.set('namespaceId', j.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"NS\",\n  \"slug\": \"ns-func\"\n}"
            },
            "url": "{{baseUrl}}/tenants/{{tenantId}}/namespaces"
          }
        },
        {
          "name": "Create table",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const j = pm.response.json();",
                  "pm.collectionVariables.set('tableId', j.id);",
                  "pm.collectionVariables.set('versionId', j.currentVersionId);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"T\",\n  \"slug\": \"tbl-func\"\n}"
            },
            "url": "{{baseUrl}}/tenants/{{tenantId}}/namespaces/{{namespaceId}}/tables"
          }
        }
      ]
    },
    {
      "name": "PlatformAdmin",
      "description": "OpenAPI tag: PlatformAdmin — tenants.",
      "item": [
        {
          "name": "List tenants",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('has items', () => Array.isArray(j.items));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/tenants?page=1&pageSize=20"
          }
        },
        {
          "name": "Get tenant by id",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('id matches', () => j.id === pm.collectionVariables.get('tenantId'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/tenants/{{tenantId}}"
          }
        }
      ]
    },
    {
      "name": "Namespaces",
      "description": "OpenAPI tag: Namespaces.",
      "item": [
        {
          "name": "List namespaces",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('has items', () => Array.isArray(j.items) && j.items.length >= 1);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/tenants/{{tenantId}}/namespaces?page=1&pageSize=20"
          }
        },
        {
          "name": "Get namespace by id",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('id matches', () => j.id === pm.collectionVariables.get('namespaceId'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/tenants/{{tenantId}}/namespaces/{{namespaceId}}"
          }
        }
      ]
    },
    {
      "name": "LookupTables",
      "description": "OpenAPI tag: LookupTables.",
