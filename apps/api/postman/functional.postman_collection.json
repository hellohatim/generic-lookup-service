    {
      "name": "TableVersions",
      "description": "OpenAPI tag: TableVersions.",
      "item": [
        {
          "name": "List versions",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('has items', () => Array.isArray(j.items) && j.items.length >= 1);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/tenants/{{tenantId}}/namespaces/{{namespaceId}}/tables/{{tableId}}/versions?page=1&pageSize=20"
          }
        },
        {
          "name": "Get version by id",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('id matches', () => j.id === pm.collectionVariables.get('versionId'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/tenants/{{tenantId}}/namespaces/{{namespaceId}}/tables/{{tableId}}/versions/{{versionId}}"
          }
        }
      ]
    },
    {
      "name": "Entries",
      "description": "OpenAPI tag: Entries — CRUD, list, search, bulk.",
      "item": [
        {
          "name": "Create entry",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const j = pm.response.json();",
                  "pm.collectionVariables.set('entryId', j.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"key\": \"from-postman\",\n  \"value\": \"hello\"\n}"
            },
            "url": "{{baseUrl}}/tenants/{{tenantId}}/namespaces/{{namespaceId}}/tables/{{tableId}}/entries"
          }
        },
        {
          "name": "Get entry by id",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('key', () => j.key === 'from-postman');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/tenants/{{tenantId}}/namespaces/{{namespaceId}}/tables/{{tableId}}/entries/{{entryId}}"
          }
        },
        {
          "name": "Get entry by key",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('one item with key', () => j.items && j.items.length === 1 && j.items[0].key === 'from-postman');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/tenants/{{tenantId}}/namespaces/{{namespaceId}}/tables/{{tableId}}/entries?key=from-postman&pageSize=1"
          }
        },
        {
          "name": "Complex search (query tree)",
          "item": [
            {
              "name": "CS — seed object entry",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status 201', () => pm.response.to.have.status(201));"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"key\": \"cs-nested\",\n  \"value\": {\n    \"region\": \"EU\",\n    \"meta\": { \"code\": \"X1\" },\n    \"label\": \"alpha\"\n  }\n}"
                },
                "url": "{{baseUrl}}/tenants/{{tenantId}}/namespaces/{{namespaceId}}/tables/{{tableId}}/entries"
              }
            },
            {
              "name": "CS — leaf keyExact",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('200', () => pm.response.to.have.status(200));",
                      "const j = pm.response.json();",
                      "pm.test('items', () => Array.isArray(j.items) && j.items.length >= 1 && j.items.some((x) => x.key === 'from-postman'));"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"query\": { \"kind\": \"keyExact\", \"key\": \"from-postman\" },\n  \"page\": 1,\n  \"pageSize\": 10\n}"
                },
                "url": "{{baseUrl}}/tenants/{{tenantId}}/namespaces/{{namespaceId}}/tables/{{tableId}}/entries/search"
              }
            },
            {
              "name": "CS — leaf keyPrefix",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"query\": { \"kind\": \"keyPrefix\", \"prefix\": \"from-\" },\n  \"page\": 1,\n  \"pageSize\": 10\n}"
                },
                "url": "{{baseUrl}}/tenants/{{tenantId}}/namespaces/{{namespaceId}}/tables/{{tableId}}/entries/search"
              }
            },
            {
              "name": "CS — leaf valueRoot partial",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"query\": {\n    \"kind\": \"valueRoot\",\n    \"value\": \"hell\",\n    \"match\": \"partial\"\n  },\n  \"page\": 1,\n  \"pageSize\": 10\n}"
                },
                "url": "{{baseUrl}}/tenants/{{tenantId}}/namespaces/{{namespaceId}}/tables/{{tableId}}/entries/search"
              }
            },
            {
              "name": "CS — leaf valuePath",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"query\": {\n    \"kind\": \"valuePath\",\n    \"path\": \"region\",\n    \"value\": \"EU\",\n    \"match\": \"exact\"\n  },\n  \"page\": 1,\n  \"pageSize\": 10\n}"
                },
                "url": "{{baseUrl}}/tenants/{{tenantId}}/namespaces/{{namespaceId}}/tables/{{tableId}}/entries/search"
              }
            },
            {
              "name": "CS — AND keyPrefix + valuePath",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"query\": {\n    \"op\": \"and\",\n    \"clauses\": [\n      { \"kind\": \"keyPrefix\", \"prefix\": \"cs-\" },\n      {\n        \"kind\": \"valuePath\",\n        \"path\": \"meta.code\",\n        \"value\": \"X1\",\n        \"match\": \"exact\"\n      }\n    ]\n  },\n  \"page\": 1,\n  \"pageSize\": 10\n}"
                },
                "url": "{{baseUrl}}/tenants/{{tenantId}}/namespaces/{{namespaceId}}/tables/{{tableId}}/entries/search"
              }
            },
            {
              "name": "CS — OR two valuePaths",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"query\": {\n    \"op\": \"or\",\n    \"clauses\": [\n      {\n        \"kind\": \"valuePath\",\n        \"path\": \"region\",\n        \"value\": \"EU\",\n        \"match\": \"exact\"\n      },\n      {\n        \"kind\": \"valuePath\",\n        \"path\": \"region\",\n        \"value\": \"US\",\n        \"match\": \"exact\"\n      }\n    ]\n  },\n  \"page\": 1,\n  \"pageSize\": 10\n}"
                },
                "url": "{{baseUrl}}/tenants/{{tenantId}}/namespaces/{{namespaceId}}/tables/{{tableId}}/entries/search"
              }
            },
            {
              "name": "CS — OR with nested AND",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"query\": {\n    \"op\": \"or\",\n    \"clauses\": [\n      {\n        \"op\": \"and\",\n        \"clauses\": [\n          {\n            \"kind\": \"valuePath\",\n            \"path\": \"meta.code\",\n            \"value\": \"X1\",\n            \"match\": \"exact\"\n          },\n          {\n            \"kind\": \"valuePath\",\n            \"path\": \"label\",\n            \"value\": \"alpha\",\n            \"match\": \"exact\"\n          }\n        ]\n      },\n      { \"kind\": \"keyExact\", \"key\": \"nonexistent-key\" }\n    ]\n  },\n  \"page\": 1,\n  \"pageSize\": 10\n}"
                },
                "url": "{{baseUrl}}/tenants/{{tenantId}}/namespaces/{{namespaceId}}/tables/{{tableId}}/entries/search"
              }
            },
            {
              "name": "CS — OR valueRoot vs keyExact",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"query\": {\n    \"op\": \"or\",\n    \"clauses\": [\n      {\n        \"kind\": \"valueRoot\",\n        \"value\": \"hello\",\n        \"match\": \"partial\"\n      },\n      { \"kind\": \"keyExact\", \"key\": \"cs-nested\" }\n    ]\n  },\n  \"page\": 1,\n  \"pageSize\": 10\n}"
                },
                "url": "{{baseUrl}}/tenants/{{tenantId}}/namespaces/{{namespaceId}}/tables/{{tableId}}/entries/search"
              }
            }
          ]
        },
        {
          "name": "Bulk JSON upsert",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('auditId', () => j.auditId);",
                  "if (j.auditId) pm.collectionVariables.set('importAuditId', j.auditId);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mode\": \"overwrite_current\",\n  \"items\": [\n    { \"key\": \"bulk-a\", \"value\": 1 },\n    { \"key\": \"bulk-b\", \"value\": \"two\" }\n  ]\n}"
            },
            "url": "{{baseUrl}}/tenants/{{tenantId}}/namespaces/{{namespaceId}}/tables/{{tableId}}/entries/bulk"
          }
        },
        {
          "name": "List entries offset",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('items array', () => Array.isArray(j.items));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/tenants/{{tenantId}}/namespaces/{{namespaceId}}/tables/{{tableId}}/entries?page=1&pageSize=20"
          }
        }
      ]
    },
    {
      "name": "Imports",
      "description": "OpenAPI tag: Imports.",
      "item": [
        {
          "name": "Excel import",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('audit', () => j.auditId && j.entriesWritten >= 1);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "{{xlsxPath}}"
                },
                { "key": "mode", "value": "overwrite_current", "type": "text" },
                { "key": "format", "value": "kv", "type": "text" }
              ]
            },
            "url": "{{baseUrl}}/tenants/{{tenantId}}/namespaces/{{namespaceId}}/tables/{{tableId}}/imports"
          }
        },
        {
          "name": "Get import audit",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/tenants/{{tenantId}}/namespaces/{{namespaceId}}/tables/{{tableId}}/imports/{{importAuditId}}"
          }
        }
      ]
    },
    {
      "name": "Exports",
      "description": "OpenAPI tag: Exports.",
      "item": [
        {
          "name": "Export xlsx",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('content type', () => pm.response.headers.get('Content-Type').includes('spreadsheet'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/tenants/{{tenantId}}/namespaces/{{namespaceId}}/tables/{{tableId}}/exports?format=flat_object&filename=fn"
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:3000/lookup/v1" },
    { "key": "tenantSlug", "value": "" },
    { "key": "tenantId", "value": "" },
    { "key": "namespaceId", "value": "" },
    { "key": "tableId", "value": "" },
    { "key": "versionId", "value": "" },
    { "key": "entryId", "value": "" },
    { "key": "importAuditId", "value": "" },
    { "key": "xlsxPath", "value": "" }
  ]
}
