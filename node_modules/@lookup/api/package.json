    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "express-openapi-validator": "^5.4.6",
    "js-yaml": "^4.1.0",
    "mongodb": "^6.12.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.5",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.8",
    "mongodb-memory-server": "^10.1.3",
    "newman": "^6.2.1",
